  });

  // ── Intersection Observer for fade-in on scroll ───────
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.animation = 'fadeInUp .6s ease forwards';
