<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Rollsthai — El sushi favorito de Lo Espejo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">
<style>
  /* ── Design Tokens ──────────────────────────────────── */
  :root {
    --red: #C0392B;
    --red-dark: #922B21;
    --red-deep: #7B0D0D;
    --red-mat: #E53935;
    --red-50: #FAECE7;
    --black: #111;
    --black-soft: #1a1a1a;
    --green: #1D9E75;
    --green-50: #E1F5EE;
    --whatsapp: #25D366;
    --whatsapp-dark: #1ebe5d;
    --gold: #FFB300;
    --gray-50: #F9F9F8;
    --gray-100: #F0EFEC;
    --gray-200: #DDD;
    --gray-400: #999;
    --gray-600: #555;
    --shadow-card: 0 4px 10px rgba(0,0,0,.06);
    --shadow-red: 0 6px 20px rgba(192,57,43,.4);
    --shadow-red-sm: 0 4px 12px rgba(229,57,53,.30);
    --display: 'Bebas Neue', Impact, sans-serif;
    --body: 'DM Sans', system-ui, sans-serif;
    --radius-pill: 999px;
    --radius-card: 28px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--body);
    color: var(--black);
    background: var(--gray-50);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  /* ── Animations ─────────────────────────────────────── */
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .5; transform: scale(.8); }
  }
  @keyframes livepulse {
    0% { box-shadow: 0 0 0 0 rgba(255,179,0,.7); }
    100% { box-shadow: 0 0 0 12px rgba(255,179,0,0); }
  }
  @keyframes ringpulse {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(1.35); opacity: 0; }
  }
  @keyframes floatup {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(32px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes countUp {
    from { transform: scale(.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* ── Header ─────────────────────────────────────────── */
  .header {
    position: sticky; top: 0; z-index: 50;
    background: var(--black);
    border-bottom: 3px solid var(--red);
    color: #fff;
    backdrop-filter: blur(10px);
  }
  .header-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 14px 24px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px;
  }
  .brand { display: flex; align-items: center; gap: 12px; }
  .brand-mark {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--red);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    border: 2px solid rgba(255,255,255,.2);
    flex-shrink: 0;
  }
  .brand-text { display: flex; flex-direction: column; line-height: 1; }
  .brand-name { font-family: var(--display); font-size: 26px; letter-spacing: .04em; }
  .brand-tag { font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: #bbb; margin-top: 3px; }

  .header-cta {
    background: var(--whatsapp); color: #fff;
    padding: 12px 22px; border-radius: var(--radius-pill);
    font-weight: 700; font-size: 14px;
    display: inline-flex; align-items: center; gap: 8px;
    transition: background .2s ease, transform .2s ease;
    box-shadow: 0 4px 12px rgba(37,211,102,.35);
    flex-shrink: 0;
  }
  .header-cta:hover { background: var(--whatsapp-dark); transform: translateY(-1px); }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    position: relative;
    background: #fff;
    padding: 80px 24px 108px;
    overflow: hidden;
  }
  .hero-bg-blob {
    position: absolute; width: 540px; height: 540px; border-radius: 50%;
    background: radial-gradient(circle, rgba(192,57,43,.08), transparent 70%);
    top: -140px; left: -130px; z-index: 0;
    pointer-events: none;
  }
  .hero-bg-blob.b {
    background: radial-gradient(circle, rgba(255,179,0,.10), transparent 70%);
    top: auto; bottom: -200px; left: auto; right: -180px;
    width: 620px; height: 620px;
  }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1.05fr 1fr; gap: 56px; align-items: center;
  }

  .hero-content { animation: fadeInUp .7s ease both; }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
    color: var(--red);
    background: var(--red-50);
    padding: 8px 14px; border-radius: var(--radius-pill);
    margin-bottom: 24px;
  }
  .eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--red);
    animation: pulse 1.5s infinite;
  }

  .hero-title {
    font-family: var(--display);
    font-size: clamp(58px, 7.4vw, 108px);
    line-height: .91;
    letter-spacing: .01em;
    color: var(--black);
  }
  .hero-title .accent { color: var(--red); }
  .hero-title .amp {
    font-family: 'DM Sans', serif; font-style: italic; font-weight: 400;
    color: var(--gold); font-size: .68em; padding: 0 .05em;
  }

  .hero-sub {
    font-size: 18px; color: var(--gray-600);
    margin-top: 24px; max-width: 480px; line-height: 1.58;
  }
  .hero-meta {
    display: flex; align-items: center; gap: 12px;
    margin-top: 24px; font-size: 14px; color: var(--gray-600);
  }
  .hero-meta-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: #fff; display: flex; align-items: center; justify-content: center;
    font-size: 18px; flex-shrink: 0;
  }
  .star-count { color: var(--gold); font-weight: 700; }

  .hero-actions {
    display: flex; align-items: center; gap: 18px;
    margin-top: 36px; flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--red); color: #fff;
    padding: 18px 30px; border-radius: var(--radius-pill);
    font-weight: 700; font-size: 16px;
    display: inline-flex; align-items: center; gap: 10px;
    box-shadow: var(--shadow-red);
    transition: all .25s cubic-bezier(.34,1.56,.64,1);
    border: none; cursor: pointer; white-space: nowrap;
  }
  .btn-primary:hover {
    background: var(--red-dark);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(192,57,43,.5);
  }
  .btn-primary:active { transform: scale(.97); }

  .btn-play {
    display: inline-flex; align-items: center; gap: 14px;
    color: var(--black); font-weight: 600; font-size: 15px;
  }
  .btn-play-icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: #fff; border: 2px solid var(--red);
    display: flex; align-items: center; justify-content: center;
    color: var(--red); font-size: 13px;
    transition: all .25s ease;
    flex-shrink: 0;
  }
  .btn-play:hover .btn-play-icon { background: var(--red); color: #fff; transform: scale(1.06); }

  /* Hero visual */
  .hero-visual {
    position: relative;
    display: flex; justify-content: center; align-items: center;
    min-height: 490px;
    animation: slideInRight .7s ease .15s both;
  }
  .plate {
    width: 450px; height: 450px; border-radius: 50%;
    background: linear-gradient(135deg, #FFD580 0%, var(--gold) 100%);
    display: flex; align-items: center; justify-content: center;
    position: relative;
    box-shadow: 0 32px 64px rgba(0,0,0,.13);
    animation: floatup 4s ease-in-out infinite;
  }
  .plate::before {
    content: ""; position: absolute; inset: -22px; border-radius: 50%;
    border: 2px dashed rgba(192,57,43,.22);
  }
  .plate-emoji {
    font-size: 210px;
    filter: drop-shadow(0 14px 32px rgba(0,0,0,.22));
    transform: rotate(-5deg);
    line-height: 1;
  }

  /* Decorative arcs */
  .arc {
    position: absolute;
    border: 5px solid; border-color: transparent;
    border-radius: 50%; pointer-events: none;
  }
  .arc.green {
    width: 390px; height: 390px;
    border-top-color: var(--green); border-right-color: var(--green);
    transform: rotate(-30deg); top: -12px; left: 28px;
    animation: spin-slow 18s linear infinite;
  }
  .arc.red {
    width: 490px; height: 490px;
    border-bottom-color: var(--red); border-left-color: var(--red);
    transform: rotate(20deg); bottom: -30px; right: 0;
    animation: spin-slow 24s linear infinite reverse;
  }
  .arc.gray {
    width: 530px; height: 530px;
    border-top-color: #ddd;
    transform: rotate(60deg); top: -30px; right: -20px;
  }

  /* Floating chips */
  .chip-float {
    position: absolute; background: #fff; border-radius: 18px;
    box-shadow: 0 8px 24px rgba(0,0,0,.10);
    padding: 14px 18px;
    display: flex; align-items: center; gap: 12px;
    z-index: 2;
  }
  .chip-float .ico {
    width: 44px; height: 44px; border-radius: 12px;
    background: var(--red-50); color: var(--red);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0;
  }
  .chip-float h5 { font-size: 14px; font-weight: 700; }
  .chip-float p { font-size: 11px; color: var(--gray-600); margin-top: 2px; }
  .chip-1 { top: 36px; right: -10px; animation: floatup 3.5s ease-in-out .5s infinite; }
  .chip-2 { top: 205px; right: -40px; animation: floatup 4s ease-in-out 1s infinite; }
  .chip-3 { bottom: 56px; right: 0; animation: floatup 3.8s ease-in-out 1.5s infinite; }

  /* ── Banner dinámico ─────────────────────────────────── */
  .banner-section { padding: 0 24px; margin-top: -44px; position: relative; z-index: 5; }
  .banner {
    max-width: 1200px; margin: 0 auto;
    background: linear-gradient(135deg, var(--red-deep) 0%, var(--red-dark) 50%, var(--red) 100%);
    border-radius: var(--radius-card);
    padding: 44px 52px;
    color: #fff;
    position: relative; overflow: hidden;
    box-shadow: 0 24px 64px -12px rgba(192,57,43,.45);
  }
  .banner::before, .banner::after {
    content: ""; position: absolute; border-radius: 50%; pointer-events: none;
  }
  .banner::before {
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(255,255,255,.10), transparent 70%);
    top: -160px; left: -110px;
  }
  .banner::after {
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(255,179,0,.18), transparent 70%);
    bottom: -110px; right: -60px;
  }
  .banner-grid {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center;
  }
  .banner-eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase;
    color: rgba(255,255,255,.85);
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 14px;
  }
  .live {
    width: 8px; height: 8px; border-radius: 50%; background: #FFB300;
    box-shadow: 0 0 0 0 rgba(255,179,0,.6);
    animation: livepulse 1.5s infinite;
    flex-shrink: 0;
  }
  .banner-title {
    font-family: var(--display);
    font-size: clamp(38px, 4.8vw, 60px);
    letter-spacing: .02em; line-height: 1;
  }
  .banner-sub { font-size: 16px; margin-top: 10px; opacity: .92; max-width: 560px; }
  .banner-right {
    display: flex; align-items: center; gap: 24px; flex-direction: column;
  }
  .banner-cta {
    background: #fff; color: var(--red);
    padding: 18px 28px; border-radius: var(--radius-pill);
    font-weight: 700; font-size: 15px; white-space: nowrap;
    display: inline-flex; align-items: center; gap: 10px;
    transition: transform .2s ease, box-shadow .2s ease;
    box-shadow: 0 4px 16px rgba(0,0,0,.15);
  }
  .banner-cta:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 8px 24px rgba(0,0,0,.2); }
  .banner-emoji { font-size: 84px; line-height: 1; filter: drop-shadow(0 8px 16px rgba(0,0,0,.3)); }

  /* ── Sections base ───────────────────────────────────── */
  .section { padding: 96px 24px; position: relative; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase;
    color: var(--red); margin-bottom: 14px; text-align: center;
  }
  .section-title {
    font-family: var(--display);
    font-size: clamp(42px, 5.6vw, 78px);
    text-align: center; line-height: 1; letter-spacing: .01em;
    margin-bottom: 18px;
  }
  .section-title .accent { color: var(--red); }
  .section-sub {
    text-align: center; color: var(--gray-600); font-size: 18px;
    max-width: 620px; margin: 0 auto 56px; line-height: 1.58;
  }

  /* ── Cómo te servimos ────────────────────────────────── */
  #como-servimos { background: var(--gray-50); }
  .serve-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px;
  }
  .serve-card {
    text-align: center; padding: 24px;
    position: relative;
    transition: transform .3s ease;
  }
  .serve-card:hover { transform: translateY(-6px); }
  .serve-circle {
    width: 200px; height: 200px; border-radius: 50%;
    background: #fff;
    margin: 0 auto 28px;
    display: flex; align-items: center; justify-content: center;
    font-size: 90px;
    box-shadow: 0 20px 40px rgba(0,0,0,.07);
    position: relative;
  }
  .serve-circle::before {
    content: ""; position: absolute; inset: -12px; border-radius: 50%;
    border: 5px solid transparent;
    border-top-color: var(--gold); border-right-color: var(--green);
    transform: rotate(-30deg);
    transition: transform .5s ease;
  }
  .serve-circle::after {
    content: ""; position: absolute; inset: -12px; border-radius: 50%;
    border: 5px solid transparent;
    border-bottom-color: var(--red); border-left-color: #FFD580;
    transform: rotate(45deg);
    transition: transform .5s ease;
  }
  .serve-card:hover .serve-circle::before { transform: rotate(30deg); }
  .serve-card:hover .serve-circle::after { transform: rotate(-45deg); }
  .serve-card h3 {
    font-family: var(--display);
    font-size: 30px; letter-spacing: .02em;
    margin-bottom: 10px;
  }
  .serve-card p { color: var(--gray-600); font-size: 15px; line-height: 1.58; max-width: 280px; margin: 0 auto; }

  /* ── Salsas / Gohan ──────────────────────────────────── */
  .gohan-bg { background: #fff; }
  .gohan-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 32px;
  }
  .gohan-card {
    background: var(--gray-50);
    border-radius: var(--radius-card);
    padding: 36px;
    border: 1.5px solid var(--gray-100);
    transition: all .28s ease;
    position: relative; overflow: hidden;
  }
  .gohan-card:hover {
    transform: translateY(-5px);
    border-color: var(--red);
    box-shadow: 0 24px 48px rgba(0,0,0,.08);
  }
  .gohan-visual {
    height: 240px; border-radius: 20px;
    display: flex; align-items: center; justify-content: center;
    font-size: 120px; margin-bottom: 24px;
    position: relative; overflow: hidden;
  }
  .gohan-visual.spicy { background: linear-gradient(135deg, #FFB300 0%, #E53935 100%); }
  .gohan-visual.cevi { background: linear-gradient(135deg, #FFD580 0%, #9ACD32 100%); }
  .gohan-pill {
    position: absolute; top: 16px; left: 16px;
    background: rgba(0,0,0,.7); color: #fff;
    padding: 6px 12px; border-radius: var(--radius-pill);
    font-size: 11px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  }
  .gohan-card h3 {
    font-family: var(--display); font-size: 34px; letter-spacing: .02em;
    margin-bottom: 10px;
  }
  .gohan-card p { color: var(--gray-600); font-size: 15px; line-height: 1.58; }
  .gohan-tags { display: flex; gap: 8px; margin-top: 18px; flex-wrap: wrap; }
  .tag {
    background: #fff; border: 1.5px solid var(--gray-200);
    padding: 6px 12px; border-radius: var(--radius-pill);
    font-size: 12px; font-weight: 600;
  }
  .tag.hot { color: var(--red); border-color: var(--red-50); background: var(--red-50); }
  .tag.green { color: var(--green); border-color: var(--green-50); background: var(--green-50); }

  /* ── Categorías ─────────────────────────────────────── */
  .cats-bg { background: var(--gray-50); }
  .cats-head {
    display: grid; grid-template-columns: 1.1fr .9fr; gap: 48px;
    align-items: end; margin-bottom: 64px;
  }
  .cats-head h2 {
    font-family: var(--display);
    font-size: clamp(46px, 6.2vw, 88px); line-height: .94; letter-spacing: .01em; text-align: left;
  }
  .cats-head h2 .accent { color: var(--red); }
  .cats-head p { color: var(--gray-600); font-size: 17px; line-height: 1.62; }
  .cats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .cat-card { text-align: center; cursor: pointer; }
  .cat-circle {
    width: 100%; aspect-ratio: 1; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 140px; margin-bottom: 24px;
    position: relative; transition: transform .35s cubic-bezier(.34,1.56,.64,1);
    overflow: hidden;
  }
  .cat-card:hover .cat-circle { transform: scale(1.05); }
  .cat-circle.green { background: #7AB89A; }
  .cat-circle.peach { background: #F4A582; }
  .cat-circle.gold { background: #FFD580; }
  .cat-circle::before {
    content: ""; position: absolute; inset: -14px; border-radius: 50%;
    border: 5px solid transparent;
    border-top-color: #FFD580; border-bottom-color: var(--red);
    transform: rotate(-15deg);
    transition: transform .5s ease;
  }
  .cat-circle::after {
    content: ""; position: absolute; inset: -14px; border-radius: 50%;
    border: 5px solid transparent;
    border-left-color: var(--green);
    transform: rotate(75deg);
    transition: transform .5s ease;
  }
  .cat-card:hover .cat-circle::before { transform: rotate(60deg); }
  .cat-card:hover .cat-circle::after { transform: rotate(-30deg); }
  .cat-card h3 {
    font-family: var(--display); font-size: 28px; letter-spacing: .02em; margin-bottom: 10px;
  }
  .cat-link {
    color: var(--red); font-weight: 700; font-size: 15px;
    display: inline-flex; align-items: center; gap: 6px;
    transition: gap .2s ease;
  }
  .cat-card:hover .cat-link { gap: 12px; }

  /* ── Reseñas Google ──────────────────────────────────── */
  .reviews-bg { background: #fff; }
  .reviews-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    margin-bottom: 48px;
  }
  .review-card {
    background: var(--gray-50);
    border: 1.5px solid var(--gray-100);
    border-radius: 24px;
    padding: 28px;
    position: relative;
    transition: all .28s ease;
    display: flex; flex-direction: column; gap: 14px;
  }
  .review-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0,0,0,.08);
    border-color: var(--gray-200);
  }
  .review-card--featured {
    background: linear-gradient(135deg, #fff8f7 0%, #fff 100%);
    border-color: rgba(192,57,43,.2);
    box-shadow: 0 8px 32px rgba(192,57,43,.08);
  }
  .review-card--featured:hover {
    border-color: var(--red);
    box-shadow: 0 20px 48px rgba(192,57,43,.15);
  }
  .review-featured-badge {
    position: absolute; top: -12px; left: 24px;
    background: var(--red); color: #fff;
    padding: 4px 14px; border-radius: var(--radius-pill);
    font-size: 11px; font-weight: 700; letter-spacing: .08em;
  }
  .review-header {
    display: flex; align-items: center; gap: 12px;
  }
  .review-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--display); font-size: 22px; color: #fff;
    flex-shrink: 0;
  }
  .review-meta { flex: 1; }
  .review-meta strong { display: block; font-size: 15px; font-weight: 700; line-height: 1.2; }
  .review-date { font-size: 12px; color: var(--gray-400); }
  .review-google-ico {
    width: 32px; height: 32px; border-radius: 8px;
    background: #fff; border: 1px solid var(--gray-200);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .review-stars { color: #FFB300; font-size: 18px; letter-spacing: 2px; }
  .review-text {
    font-size: 15px; line-height: 1.65; color: var(--black);
    flex: 1;
    font-style: italic;
  }
  .review-scores {
    display: flex; gap: 8px; flex-wrap: wrap;
    padding-top: 14px;
